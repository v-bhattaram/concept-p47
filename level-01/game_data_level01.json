{
  "level": "level-01",
  "location_groups": [
    {
      "location_group": "ZC-Opening",
      "locations": [
        {
          "location": "ZC-Opening",
          "triggers": [
            {
              "Order-Trigger": "3-SURD SOS",
              "trigger": "SURD SOS",
              "location$$trigger": "ZC-Opening$$SURD SOS",
              "dialogues": [
                {
                  "character": "SURD",
                  "dialogue": "Critical S.O.S. This is SUR-RD. Orbital Command, can you read me?",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-Opening/3-SURD SOS/01-surd.mp3"
                },
                {
                  "character": "SURD",
                  "dialogue": "Critical S.O.S. This is SUR-RD. Orbital Command, respond.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-Opening/3-SURD SOS/02-surd.mp3"
                },
                {
                  "character": "SURD",
                  "dialogue": "Critical S.O.S. This is SUR_RD. Armada down. Any station, respond.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-Opening/3-SURD SOS/03-surd.mp3"
                },
                {
                  "character": "SURD",
                  "dialogue": "Critical S.O.S. Zegas Armada 47. Does anyone copy.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-Opening/3-SURD SOS/04-surd.mp3"
                },
                {
                  "character": "SURD",
                  "dialogue": "...S.O.S.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-Opening/3-SURD SOS/05-surd.mp3"
                }
              ]
            },
            {
              "Order-Trigger": "5-First Look",
              "trigger": "First Look",
              "location$$trigger": "ZC-Opening$$First Look",
              "dialogues": [
                {
                  "character": "Player",
                  "dialogue": "Where is everyone?",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Opening/5-First Look/01-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Opening/5-First Look/01-Player-Male.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "This was an armada. There should be signals, bodies, something.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Opening/5-First Look/02-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Opening/5-First Look/02-Player-Male.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "I need comms. If anyone survived, they will try to reach Orbital Command.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Opening/5-First Look/03-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Opening/5-First Look/03-Player-Male.mp3"
                }
              ]
            }
          ]
        },
        {
          "location": "ZC-Planet47",
          "triggers": [
            {
              "Order-Trigger": "1-Find Comms",
              "trigger": "Find Comms",
              "location$$trigger": "ZC-Planet47$$Find Comms",
              "dialogues": [
                {
                  "character": "Player",
                  "dialogue": "None of my comms are working. I need to find another unit.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47/1-Find Comms/01-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47/1-Find Comms/01-Player-Male.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "Let me check the crashed pods.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47/1-Find Comms/02-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47/1-Find Comms/02-Player-Male.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "If Orbital Command is listening, I need a transmitter strong enough to punch through this atmosphere.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47/1-Find Comms/03-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47/1-Find Comms/03-Player-Male.mp3"
                }
              ]
            },
            {
              "Order-Trigger": "2-Suit Up",
              "trigger": "Suit Up",
              "location$$trigger": "ZC-Planet47$$Suit Up",
              "dialogues": [
                {
                  "character": "Player",
                  "dialogue": "The suit is damaged. I need to find the rest of it before the environment kills me.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47/2-Suit Up/01-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47/2-Suit Up/01-Player-Male.mp3"
                }
              ]
            },
            {
              "Order-Trigger": "3-Scale of the Crash",
              "trigger": "Scale of the Crash",
              "location$$trigger": "ZC-Planet47$$Scale of the Crash",
              "dialogues": [
                {
                  "character": "Player",
                  "dialogue": "The wreckage goes beyond the ridge.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47/3-Scale of the Crash/01-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47/3-Scale of the Crash/01-Player-Male.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "This is too much ground to cover on foot.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47/3-Scale of the Crash/02-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47/3-Scale of the Crash/02-Player-Male.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "I quickly need to find Food, water, comms, survivors. One thing at a time.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47/3-Scale of the Crash/03-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47/3-Scale of the Crash/03-Player-Male.mp3"
                }
              ]
            }
          ]
        },
        {
          "location": "ZC-Planet47-Creatures-Intro",
          "triggers": [
            {
              "Order-Trigger": "1-Sounds in the Smoke",
              "trigger": "Sounds in the Smoke",
              "location$$trigger": "ZC-Planet47-Creatures-Intro$$Sounds in the Smoke",
              "dialogues": [
                {
                  "character": "Player",
                  "dialogue": "(quiet) What is that sound?",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47-Creatures-Intro/1-Sounds in the Smoke/01-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47-Creatures-Intro/1-Sounds in the Smoke/01-Player-Male.mp3"
                }
              ]
            },
            {
              "Order-Trigger": "2-What Was That",
              "trigger": "What Was That",
              "location$$trigger": "ZC-Planet47-Creatures-Intro$$What Was That",
              "dialogues": [
                {
                  "character": "Player",
                  "dialogue": "What the hell are these creatures?",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47-Creatures-Intro/2-What Was That/01-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47-Creatures-Intro/2-What Was That/01-Player-Male.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "Zegas said this planet was uninhabited.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47-Creatures-Intro/2-What Was That/02-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47-Creatures-Intro/2-What Was That/02-Player-Male.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "Better hide and find comms soon.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-Planet47-Creatures-Intro/2-What Was That/03-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-Planet47-Creatures-Intro/2-What Was That/03-Player-Male.mp3"
                }
              ]
            }
          ]
        },
        {
          "location": "ZC-What-Now",
          "triggers": [
            {
              "Order-Trigger": "1-No Survivors Found",
              "trigger": "No Survivors Found",
              "location$$trigger": "ZC-What-Now$$No Survivors Found",
              "dialogues": [
                {
                  "character": "Player",
                  "dialogue": "I need food and water. I cannot find working comms anywhere.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-What-Now/1-No Survivors Found/01-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-What-Now/1-No Survivors Found/01-Player-Male.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "No hunting. No unknown water. Zegas survival stock only.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-What-Now/1-No Survivors Found/02-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-What-Now/1-No Survivors Found/02-Player-Male.mp3"
                }
              ]
            },
            {
              "Order-Trigger": "2-SURD Terminal Found",
              "trigger": "SURD Terminal Found",
              "location$$trigger": "ZC-What-Now$$SURD Terminal Found",
              "dialogues": [
                {
                  "character": "SURD",
                  "dialogue": "Who is this? Identify yourself.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-What-Now/2-SURD Terminal Found/01-surd.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "I am the player. We crashed. I cannot find comms. What is the status of the survivors?",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-What-Now/2-SURD Terminal Found/02-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-What-Now/2-SURD Terminal Found/02-Player-Male.mp3"
                },
                {
                  "character": "SURD",
                  "dialogue": "Crash event confirmed. I lost contact with life support systems. I do not have survivor data.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-What-Now/2-SURD Terminal Found/03-surd.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "I have not found anyone. Not even bodies.",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-What-Now/2-SURD Terminal Found/04-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-What-Now/2-SURD Terminal Found/04-Player-Male.mp3"
                },
                {
                  "character": "SURD",
                  "dialogue": "Unknown variable. Do not conclude total loss without data.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-What-Now/2-SURD Terminal Found/05-surd.mp3"
                },
                {
                  "character": "SURD",
                  "dialogue": "I cannot establish comms with Orbital Command from this terminal.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-What-Now/2-SURD Terminal Found/06-surd.mp3"
                }
              ]
            },
            {
              "Order-Trigger": "3-Find Type-P Terminal",
              "trigger": "Find Type-P Terminal",
              "location$$trigger": "ZC-What-Now$$Find Type-P Terminal",
              "dialogues": [
                {
                  "character": "SURD",
                  "dialogue": "Find a Type-P Terminal. It can hold my active node and allow portable transfer.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-What-Now/3-Find Type-P Terminal/01-surd.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "Where?",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-What-Now/3-Find Type-P Terminal/02-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-What-Now/3-Find Type-P Terminal/02-Player-Male.mp3"
                },
                {
                  "character": "SURD",
                  "dialogue": "Three possible locations within the crash zone. I am transmitting coordinates.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-What-Now/3-Find Type-P Terminal/03-surd.mp3"
                },
                {
                  "character": "Player",
                  "dialogue": "And if none of them are intact?",
                  "audio_file_location_female": "dialogs/ZC-Opening/ZC-What-Now/3-Find Type-P Terminal/04-Player-Female.mp3",
                  "audio_file_location_male": "dialogs/ZC-Opening/ZC-What-Now/3-Find Type-P Terminal/04-Player-Male.mp3"
                },
                {
                  "character": "SURD",
                  "dialogue": "Then keep looking. The alternative is worse.",
                  "audio_file_location": "dialogs/ZC-Opening/ZC-What-Now/3-Find Type-P Terminal/05-surd.mp3"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}